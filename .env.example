# UZI-Skill · 本地环境变量（可选）
# 把本文件复制为 .env 并填入你自己的值：
#   cp .env.example .env
#   # 然后编辑 .env 填 key

# ─── 东财妙想 Skills Hub API（推荐配置）──────────────────────
# 设置后 UZI-Skill 会优先使用官方 NLP API 做：
#   1. 中文名纠错（"北部港湾" 自动识别为 "北部湾港"）
#   2. 股票行情快照（稳定性远高于爬 push2.eastmoney.com）
# 获取 key（免费）: https://dl.dfcfs.com/m/itc4
MX_APIKEY=

# ─── DART 电子公示 OpenAPI（한국 시장 · K market）─────────────
# 한국 상장사 공시 / 재무제표 / 지배구조(최대주주·임원) 연동에 사용.
# 네이버 신 API에 없는 11_governance 차원과 공시 원문은 DART가 필수.
# 키 발급(무료): https://opendart.fss.or.kr/  → 인증키 신청/관리 (40자리 hex)
DART_APIKEY=

# ─── 其他可选 ─────────────────────────────────────────────
# STOCK_NO_CACHE=1        # 禁用所有 API 缓存，强制重新拉取
# UZI_NO_AUTO_OPEN=1      # 分析完不自动打开浏览器
